# Terraform state — never commit these
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Variable files with real values — use terraform.tfvars.example as a template
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# macOS
.DS_Store
